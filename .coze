[project]
requires = ["nodejs-24"]

[dev]
build = ["sh", "-c", "cd web && npm install"]
run = ["sh", "-c", "cd web && npm run dev -- --host 0.0.0.0 --port ${DEPLOY_RUN_PORT}"]

[deploy]
build = ["sh", "-c", "cd web && npm install && npm run build"]
run = ["sh", "-c", "cd web && npm run preview -- --host 0.0.0.0 --port ${DEPLOY_RUN_PORT}"]
